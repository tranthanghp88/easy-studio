{
  "name": "easy-thumbnail-studio",
  "version": "7.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "electron": "wait-on http://127.0.0.1:5173 && electron .",
    "start": "concurrently -k \"npm run dev\" \"npm run electron\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.0",
    "typescript": "^5.6.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@google/genai": "^1.21.0",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "^36.0.0",
    "electron-builder": "^25.1.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.easystudio.thumbnailstudio",
    "productName": "Easy Thumbnail Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://example.com/updates/"
      }
    ]
  }
}