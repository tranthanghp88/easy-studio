{
  "name": "easy-vietnamese-voice-studio",
  "version": "1.0.4",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "vite build",
    "start": "electron .",
    "fix:deps": "npm install && npm install ffmpeg-static --save"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "vite": "latest",
    "typescript": "latest",
    "react": "latest",
    "react-dom": "latest",
    "electron": "latest",
    "concurrently": "latest",
    "wait-on": "latest",
    "ffmpeg-static": "latest"
  },
  "devDependencies": {}
}